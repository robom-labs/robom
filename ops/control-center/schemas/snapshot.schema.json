{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "robom-hq snapshot",
  "type": "object",
  "required": ["product", "phase", "generatedAt", "company", "apps", "departments", "agents", "runs", "connections"],
  "properties": {
    "phase": { "const": "phase-1-readonly" },
    "company": { "type": "object", "required": ["trafficLight", "apps", "employees", "tasks"] },
    "apps": { "type": "array", "items": { "type": "object", "required": ["id", "name", "health", "registered"] } },
    "runs": { "type": "array", "description": "실제 이벤트로 도출된 작업만. 증거 없으면 비어 있음(연출 금지)." },
    "agents": { "type": "array" }, "departments": { "type": "array" },
    "approvals": { "type": "array" }, "events": { "type": "array" }, "connections": { "type": "object" }
  }
}
