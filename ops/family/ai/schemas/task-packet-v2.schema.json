{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ROBOM Task Packet v2 (Claude/Codex 공용, migration 호환)",
  "_note": "runner는 Codex 소유 HQ runtime(scripts/control-center)이다. 이 스키마는 계약(정본)만 정의하며 runner 재작성은 Codex와 조율한다. schema 1 packet도 읽을 수 있어야 하고 쓰기부터 schema 2를 쓴다.",
  "type": "object",
  "required": ["schemaVersion", "task_id", "target_repositories", "title", "acceptance_criteria"],
  "properties": {
    "schemaVersion": { "const": 2 },
    "task_id": { "type": "string" },
    "target_apps": { "type": "array" },
    "target_repositories": { "type": "array" },
    "base_shas": { "type": "object" },
    "title": { "type": "string" },
    "problem": { "type": "string" },
    "desired_outcome": { "type": "string" },
    "must_preserve": { "type": "array" },
    "acceptance_criteria": { "type": "array" },
    "priority": { "type": "string" },
    "risk_grade": { "enum": ["A", "B", "C", "D"] },
    "autonomy": { "type": "string" },
    "allowed_paths": { "type": "array" },
    "forbidden_paths": { "type": "array" },
    "required_tests": { "type": "array" },
    "production_urls": { "type": "array" },
    "release_policy": { "type": "string" },
    "rollback_plan": { "type": "string" },
    "context_profile": { "type": "string" },
    "context_level": { "enum": ["L0", "L1", "L2", "L3", "L4"] },
    "context_manifest_path": { "type": "string" },
    "context_budget": { "type": "object" },
    "canonical_hashes": { "type": "object" },
    "retry_policy": { "type": "object", "properties": { "waitReason": {"type":"string"}, "retryAt": {"type":["string","null"]}, "retryStrategy": {"type":"string"}, "attempt": {"type":"number"}, "maxAttempts": {"type":"number"}, "providerResetAt": {"type":["string","null"]} } },
    "executor_fallback_allowed": { "type": "boolean" },
    "created_at": { "type": "string" }
  }
}
